<?xml version="1.0" encoding="UTF-8"?>
<Devices>

<!-- ===================================================== -->
<!-- ROOMIFY OBSERVER -->
<!-- ===================================================== -->
<Device type="custom" id="roomifyObserver" name="Roomify Observer">

    <Name>Roomify Observer</Name>

    <ConfigUI>


        <Field id="schemaVersion"
                hidden="true"
            type="textfield"
            defaultValue="1.0">
            <Label>Schema Version</Label>
        </Field>

        <Field id="label1" type="label" alignText="left">
            <Label>This device is owned and managed by the Roomify plugin.</Label>
        </Field>

        <Field id="label2" type="label" alignText="left">
            <Label>It is a read-only observation surface that reports Roomify’s current global state.</Label>
        </Field>

        <Field id="label3" type="label" alignText="left">
            <Label>It is not configurable and must not be used for control or automation input.</Label>
        </Field>

        <Field id="label4" type="label" alignText="left">
            <Label>It contains no actions or methods.</Label>
        </Field>

        <Field id="label5" type="label" alignText="left">
            <Label>It does not participate in Roomify control logic.</Label>
        </Field>
    </ConfigUI>

    <States>
        <State id="houseMode">
            <ValueType>String</ValueType>
            <TriggerLabel>House Mode</TriggerLabel>
            <ControlPageLabel>House Mode</ControlPageLabel>
        </State>

        <State id="roomDormancyCutoffEnabled">
            <ValueType>String</ValueType>
            <TriggerLabel>Room Dormancy Cutoff Enabled</TriggerLabel>
            <ControlPageLabel>Room Dormancy Cutoff Enabled</ControlPageLabel>
        </State>


        <State id="occupancyAutomationEnabled">
            <ValueType>String</ValueType>
            <TriggerLabel>Room Occupancy Automation Enabled</TriggerLabel>
            <ControlPageLabel>RoomOccupancy Automation Enabled</ControlPageLabel>
        </State>

        <State id="roomAutomationCalmingPeriod">
            <ValueType>String</ValueType>
            <TriggerLabel>Room Automation Calming Period</TriggerLabel>
            <ControlPageLabel>Room Automation Calming Period</ControlPageLabel>
        </State>

        <State id="houseModesEnabled">
            <ValueType>String</ValueType>
            <TriggerLabel>House Modes Enabled</TriggerLabel>
            <ControlPageLabel>House Modes Enabled</ControlPageLabel>
        </State>

        <State id="lastPublishTimestamp">
            <ValueType>String</ValueType>
            <TriggerLabel>Last Publish Time</TriggerLabel>
            <ControlPageLabel>Last Publish Time</ControlPageLabel>
        </State>

    </States>

</Device>
<!-- ===================================================== -->
<!-- ROOMIFY ROOM -->
<!-- ===================================================== -->


    <Device type="dimmer" id="roomifyRoom" name="Roomify Room">

        <Name>Roomify Room</Name>

        <ConfigUI>

            <!-- ===================================================== -->
            <!-- ROOM BEHAVIOR -->
            <!-- ===================================================== -->

            <Field id="schemaVersion"
                type="textfield"
                hidden="true"
                defaultValue="1.0">
                <Label>Schema Version</Label>
            </Field>



            <Field id="label1" type="label" alignText="center">
                <Label>Roomify Definition</Label>
            </Field>

            <Field id="roomType" type="menu">
                <Label>Room Type</Label>
                <Description>Select the functional type of this room.</Description>

                <List>
                    <Option value="BEDROOM">Bedroom</Option>
                    <Option value="BATHROOM">Bathroom</Option>
                    <Option value="CLOSET">Closet</Option>
                    <Option value="DININGROOM">Dining Room</Option>
                    <Option value="GARAGE">Garage</Option>
                    <Option value="HALLWAY">Hallway</Option>
                    <Option value="STAIRWAY">Stairway</Option>
                    <Option value="KITCHEN">Kitchen</Option>
                    <Option value="LIVINGROOM">Living Room</Option>
                    <Option value="MEDIAROOM">Media Room</Option>
                    <Option value="OFFICE">Office</Option>
                    <Option value="PATIO">Patio</Option>
                    <Option value="UTILITY">Utility</Option>
                </List>
            </Field>

            <Field id="controlledDevices"
                type="list"
                multiple="true"
                rows="8">
                <Label>Controlled Devices</Label>
                <List class="indigo.devices"/>
            </Field>


            <Field id="roomDormancyCutoffEnabled"
                type="checkbox"
                hidden="true"
                defaultValue="true">
                <Label>Room Dormancy Cutoff Enabled (hidden)</Label>
            </Field>

            <Field id="occupancyAutomationEnabled"
                type="checkbox"
                hidden="true"
                defaultValue="true">
                <Label>Room Occupancy Automations Enabled (hidden)</Label>
            </Field>

            <Field id="phasedLightingEnabled"
                type="checkbox"
                hidden="true"
                defaultValue="true">
                <Label>Enable Phased Lighting</Label>
            </Field>

            <Field type="separator" id="sep0" 
                visibleBindingId="roomDormancyCutoffEnabled"
                visibleBindingValue="true"
               alignText="center">
            </Field>
            


            <Field id="label0" type="label" alignText="center"
                visibleBindingId="roomDormancyCutoffEnabled"
                visibleBindingValue="true">
                <Label>Room Dormancy / Latency Cutoff</Label>
            </Field>

            <Field id="roomDormancyCutoffActive"
                type="checkbox"
                defaultValue="false"
                visibleBindingId="roomDormancyCutoffEnabled"
                visibleBindingValue="true">
                <Label>Activate</Label>
            </Field>

            <Field id="roomDormancyCutoff"
                type="menu"
                defaultValue=""
                visibleBindingId="roomDormancyCutoffActive"
                visibleBindingValue="true">
                <Label>Allowed Dormancy Duration</Label>

                <List>
                    <Option value="">Follow Global Default</Option>
                    <Option value="2">2 Minutes</Option>
                    <Option value="30">30 Minutes</Option>
                    <Option value="60">60 Minutes</Option>
                    <Option value="90">90 Minutes</Option>
                    <Option value="120">2 Hours</Option>
                    <Option value="180">3 Hours</Option>
                    <Option value="240">4 Hours</Option>
                    <Option value="300">5 Hours</Option>
                    <Option value="360">6 Hours</Option>
                    <Option value="540">9 Hours</Option>
                    <Option value="720">12 Hours</Option>
                    <Option value="1080">18 Hours</Option>
                    <Option value="1440">24 Hours</Option>
                </List>

                <Description>
                    Time before this room is subject to dormancy cutoff
                </Description>
            </Field>

            <Field type="separator" id="sep1" 
                visibleBindingId="roomDormancyCutoffEnabled"
                visibleBindingValue="true">
            </Field>


            <Field type="label" id="label1b" alignText="center"
                visibleBindingId="occupancyAutomationEnabled"
                visibleBindingValue="true">
                <Label>Occupancy-Triggered Automation</Label>
            </Field>

            <Field id="roomOccupancyAutomationActive"
                type="checkbox"
                defaultValue="false"
                visibleBindingId="occupancyAutomationEnabled"
                visibleBindingValue="true">
                <Label>Activate</Label>
            </Field>

            <Field id="occupancyIndicators"
                type="list"
                multiple="true"
                rows="8"
                visibleBindingId="roomOccupancyAutomationActive"
                visibleBindingValue="true">
                <Label>Occupancy Indicators</Label>
                <List class="indigo.devices"/>
            </Field>

            <Field id="initialBrightness"
                type="textfield"
                defaultValue="80"
                visibleBindingId="roomOccupancyAutomationActive"
                visibleBindingValue="true">
                <Label>Initial Brightness (%)</Label>
            </Field>

            <Field id="initialTimeout"
                type="textfield"
                defaultValue="5"
                visibleBindingId="roomOccupancyAutomationActive"
                visibleBindingValue="true">
                <Label>Duration (minutes)</Label>
            </Field>


            <Field id="showAdvancedSettings"
                type="checkbox"
                defaultValue="false"
                visibleBindingId="roomOccupancyAutomationActive"
                visibleBindingValue="true">
                <Label>Show Advanced Settings</Label>
            </Field>

            <Field id="occupancyAuthority" type="menu"
                visibleBindingId="showAdvancedSettings"
                visibleBindingValue="true">
                <Label>Occupancy Authority</Label>
                <List class="self" filter="stuff" method="deviceList"/>
            </Field>

            <Field id="vacancyAuthority" type="menu"
                visibleBindingId="showAdvancedSettings"
                visibleBindingValue="true">
                <Label>Vacancy Authority</Label>
                <List class="self" filter="stuff" method="deviceList"/>
            </Field>


            <Field id="delayedBrightness"
                type="textfield"
                defaultValue="60"
                visibleBindingId="showAdvancedSettings"
                visibleBindingValue="true">
                <Label>Delayed Brightness (%)</Label>
            </Field>

            <Field id="delayedMinutes"
                type="textfield"
                defaultValue="5"
                visibleBindingId="showAdvancedSettings"
                visibleBindingValue="true">
                <Label>Delay minutes:</Label>
            </Field>

            <Field id="outroBrightness"
                type="textfield"
                defaultValue="20"
                visibleBindingId="showAdvancedSettings"
                visibleBindingValue="true">
                <Label>Outro Brightness (%)</Label>
            </Field>

            <Field id="outroMinutes"
                type="textfield"
                defaultValue="2"
                visibleBindingId="showAdvancedSettings"
                visibleBindingValue="true">
                <Label>Outro Minutes</Label>
            </Field>


            <Field id="label3" type="label" alignText="center"
                visibleBindingId="showAdvancedSettings"
                visibleBindingValue="true">>
                <Label>Execution Boundaries</Label>
            </Field>

            <Field id="automationGates" 
                type="list"
                multiple="true"
                rows="8"
                visibleBindingId="showAdvancedSettings"
                visibleBindingValue="true">
                <Label>Optional Gating Device(s)</Label>
                <List class="self" filter="stuff" method="deviceList"/>
            </Field>

            <Field id="autoOffBrightness"
                type="menu"
                defaultValue="0"
                visibleBindingId="showAdvancedSettings"
                visibleBindingValue="true">
                <Label>Brighnesst to invoke when OFF is autometed</Label>

                <List>
                    <Option value="0">None. Off=Off</Option>
                    <Option value="5">5%</Option>
                    <Option value="10">10%</Option>
                    <Option value="15">15%</Option>
                    <Option value="20">20%</Option>
                    <Option value="25">25%</Option>
                </List>
            </Field>

            <Field id="autoBrightnessLowLimit"
                type="menu"
                defaultValue="Default"
                visibleBindingId="showAdvancedSettings"
                visibleBindingValue="true">
                <Label>Lower limit on auto brightness</Label>

                <List>
                    <Option value="Default">Defer to Room Type</Option>
                    <Option value="0">5%</Option>
                    <Option value="5">5%</Option>
                    <Option value="10">10%</Option>
                    <Option value="15">15%</Option>
                    <Option value="20">20%</Option>
                    <Option value="30">30%</Option>
                    <Option value="40">40%</Option>
                    <Option value="50">50%</Option>
                    <Option value="60">60%</Option>
                    <Option value="70">70%</Option>
                    <Option value="80">80%</Option>
                    <Option value="90">90%</Option>
                    <Option value="100">100%</Option>
                </List>
            </Field>

            <Field id="autoBrightnessHighLimit"
                type="menu"
                defaultValue="Default"
                visibleBindingId="showAdvancedSettings"
                visibleBindingValue="true">
                <Label>Upper limit on auto brightness</Label>

                <List>
                    <Option value="Default">Defer to Room Type</Option>
                    <Option value="0">0%</Option>
                    <Option value="5">5%</Option>
                    <Option value="10">10%</Option>
                    <Option value="15">15%</Option>
                    <Option value="20">20%</Option>
                    <Option value="30">30%</Option>
                    <Option value="40">40%</Option>
                    <Option value="50">50%</Option>
                    <Option value="60">60%</Option>
                    <Option value="70">70%</Option>
                    <Option value="80">80%</Option>
                    <Option value="90">90%</Option>
                    <Option value="100">100%</Option>
                </List>
            </Field>


            <Field type="separator" id="sep4" >
                visibleBindingId="roomOccupancyAutomationActive"
                visibleBindingValue="true" alignText="center">
            </Field>



        </ConfigUI>

        <States>
            <State id="brightness">
                <ValueType>Number</ValueType>
                <TriggerLabel>brightness</TriggerLabel>
                <ControlPageLabel>brightness</ControlPageLabel>
            </State>

            <State id="phasedLightingEnabled">
                <ValueType>Boolean</ValueType>
                <TriggerLabel>Phased</TriggerLabel>
                <ControlPageLabel>Phased</ControlPageLabel>
            </State>

            <State id="onState">
                <ValueType>Boolean</ValueType>
                <TriggerLabel>On/Off</TriggerLabel>
                <ControlPageLabel>On/Off</ControlPageLabel>
            </State>

            <State id="initialBrightness">
                <ValueType>Number</ValueType>
                <TriggerLabel>Initial Brightness</TriggerLabel>
                <ControlPageLabel>Initial Brightness</ControlPageLabel>
            </State>

            <State id="delayedBrightness">
                <ValueType>Number</ValueType>
                <TriggerLabel>Delayed Brightness</TriggerLabel>
                <ControlPageLabel>Delayed Brightness</ControlPageLabel>
            </State>

            <State id="outroBrightness">
                <ValueType>Number</ValueType>
                <TriggerLabel>Outro Brightness</TriggerLabel>
                <ControlPageLabel>Outro Brightness</ControlPageLabel>
            </State>

            <State id="lightingPhase">
                <ValueType>String</ValueType>
                <TriggerLabel>Lighting Phase</TriggerLabel>
                <ControlPageLabel>Lighting Phase</ControlPageLabel>
            </State>            

            <State id="occupied">
                <ValueType>Boolean</ValueType>
                <TriggerLabel>Occupied</TriggerLabel>
                <ControlPageLabel>Occupied</ControlPageLabel>
            </State>

            <State id="roomOccupancyAutomationActive">
                <ValueType>Boolean</ValueType>
                <TriggerLabel>Automations Active</TriggerLabel>
                <ControlPageLabel>Automations Active</ControlPageLabel>
            </State>

            <State id="automationsAuthorized">
                <ValueType>Boolean</ValueType>
                <TriggerLabel>Automations Authorized</TriggerLabel>
                <ControlPageLabel>Automations Authorized</ControlPageLabel>
            </State>

            <State id="roomDormancyCutoffActive">
                <ValueType>Boolean</ValueType>
                <TriggerLabel>Room Dormancy Cutoff Active</TriggerLabel>
                <ControlPageLabel>Room Dormancy Cutoff Active</ControlPageLabel>
            </State>


            <State id="watchdogMinutes">
                <ValueType>Number</ValueType>
                <TriggerLabel>Watchdog Minutes</TriggerLabel>
                <ControlPageLabel>Watchdog Minutes</ControlPageLabel>
            </State>

            <State id="watchdogCutoff">
                <ValueType>Number</ValueType>
                <TriggerLabel>Watchdog Cutoff</TriggerLabel>
                <ControlPageLabel>Watchdog Cutoff</ControlPageLabel>
            </State>

            <State id="watchdogCutoffDisplay">
                <ValueType>String</ValueType>
                <TriggerLabel>Watchdog Cutoff Display</TriggerLabel>
                <ControlPageLabel>Watchdog Cutoff Display s</ControlPageLabel>
            </State>

            <State id="occupancyCutoff">
                <ValueType>Number</ValueType>
                <TriggerLabel>Occupancy Cutoff</TriggerLabel>
                <ControlPageLabel>Occupancy Cutoff</ControlPageLabel>
            </State>

            <State id="occupancyCutoffUI">
