            </State>

            <State id="automationStateUI">
                <ValueType>String</ValueType>
                <TriggerLabel>Automation State</TriggerLabel>
                <ControlPageLabel>Automation State UI</ControlPageLabel>
            </State>

            <State id="delayedLightingStarttime">
                <ValueType>Number</ValueType>
                <TriggerLabel>Delayed LIgthing Startup</TriggerLabel>
                <ControlPageLabel>Delayed Lighting Startup</ControlPageLabel>
            </State>

            <State id="delayedLightingStarttimeUI">
                <ValueType>String</ValueType>
                <TriggerLabel>Delayed Lighting Start UI</TriggerLabel>
                <ControlPageLabel>Delayed LIghting Start UI</ControlPageLabel>
            </State>


            <State id="outroLightingStarttime">
                <ValueType>Number</ValueType>
                <TriggerLabel>Outrto Startup</TriggerLabel>
                <ControlPageLabel>Outro Startup</ControlPageLabel>
            </State>

            <State id="outroLightingStarttimeUI">
                <ValueType>String</ValueType>
                <TriggerLabel>Outro Start UI</TriggerLabel>
                <ControlPageLabel>Outro Start UI</ControlPageLabel>
            </State>

            <State id="minutesRemaining">
                <ValueType>Number</ValueType>
                <TriggerLabel>Minutes Reamining</TriggerLabel>
                <ControlPageLabel>Minutes Remaining</ControlPageLabel>
            </State>

            <State id="activeModifier">
                <ValueType>String</ValueType>
                <TriggerLabel>Active Modifier</TriggerLabel>
                <ControlPageLabel>Active Modifier</ControlPageLabel>
            </State>

            <State id="nextEvaluationTime">
